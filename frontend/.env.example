# Where the browser calls the Python API (upload, etc.).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Where Next.js Route Handlers call the Python API (Chef /copilot proxy).
# In Docker Compose or Dokploy, set this to the backend service URL on the Docker network,
# for example http://recipe-backend:8000 — not localhost unless backend runs in the same container.
# API_INTERNAL_BASE_URL=
